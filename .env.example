# Environment configuration

# Application Environment (development, production)
APP_ENV=development
NODE_ENV=development

# Database Configuration
POSTGRES_USER=nbd_user
POSTGRES_PASSWORD=password
POSTGRES_DB=nbd_db
DATABASE_URL=postgresql://nbd_user:password@db:5432/nbd_db

# SMTP Configuration
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
MAIL_FROM=alerts@nbd-wetland.org

# Google Service Account Credentials
GOOGLE_APPLICATION_CREDENTIALS=/credentials/your-service-account.json
GCS_BUCKET_NAME=your-gcs-bucket-name

# NFS Local Storage Configuration
STORAGE_DIR=/app/storage
SECRET_KEY=your_hmac_secret_key_here

# KoboToolbox API Integration
KOBOTOOLBOX_API_URL=https://eu.kobotoolbox.org
KOBOTOOLBOX_API_TOKEN=your_actual_token_here

# WhatsApp Meta Cloud API
# App Secret from Meta Developer Portal (used for webhook signature verification)
WHATSAPP_APP_SECRET=your_meta_app_secret_here
# Verify Token you set in Meta Developer Portal > Webhooks > Verify Token
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
# Permanent access token from Meta Developer Portal > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
# Phone Number ID from Meta Developer Portal > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Note: WhatsApp media is stored in GCS_BUCKET_NAME under path:
#   {APP_ENV}/whatsapp/{uuid}.{ext}  (e.g. production/whatsapp/3fa8...jpg)
