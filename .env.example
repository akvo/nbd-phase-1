# Environment configuration

# Application Environment (development, production)
APP_ENV=development
NODE_ENV=development

# Database Configuration
POSTGRES_USER=nbd_user
POSTGRES_PASSWORD=password
POSTGRES_DB=nbd_db
DATABASE_URL=postgresql://nbd_user:password@db:5432/nbd_db

# SMTP Configuration
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
MAIL_FROM=alerts@nbd-wetland.org

# NFS Local Storage Configuration
STORAGE_DIR=/app/storage
SECRET_KEY=your_hmac_secret_key_here

# KoboToolbox API Integration
KOBOTOOLBOX_API_URL=https://eu.kobotoolbox.org
KOBOTOOLBOX_API_TOKEN=your_actual_token_here
KOBOTOOLBOX_API_TIMEOUT=60.0
KOBO_FORM_NAME_PREFIX=
KOBO_FORM_NAME_SUFFIX=
KOBO_SYNC_INTERVAL_MINUTES=60

# Google OAuth2 - Client ID only (no secret needed for ID token verification)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT Session - reuses SECRET_KEY, configurable expiry
JWT_EXPIRY_HOURS=24

# WhatsApp Twilio API Configuration
# Twilio Account SID (found in Twilio console)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Twilio Auth Token (found in Twilio console)
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio WhatsApp Sender Number (prefixed with whatsapp:)
TWILIO_NUMBER=whatsapp:+14155238886
# Note: WhatsApp media is stored in GCS_BUCKET_NAME under path:
#   {APP_ENV}/whatsapp/{uuid}.{ext}  (e.g. production/whatsapp/3fa8...jpg)

